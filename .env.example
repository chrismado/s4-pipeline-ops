# GPU Monitoring
S4OPS_POLL_INTERVAL=5
S4OPS_GPU_TEMP_WARNING=80
S4OPS_GPU_TEMP_CRITICAL=90
S4OPS_VRAM_USAGE_WARNING=0.85
S4OPS_VRAM_USAGE_CRITICAL=0.95

# Job Scheduler
S4OPS_MAX_CONCURRENT_JOBS=4
S4OPS_JOB_TIMEOUT_HOURS=24
S4OPS_RETRY_MAX_ATTEMPTS=3

# Alerting
S4OPS_ALERT_BACKENDS=["log"]
S4OPS_SLACK_WEBHOOK_URL=
S4OPS_WEBHOOK_URL=

# Dashboard API
S4OPS_API_HOST=0.0.0.0
S4OPS_API_PORT=8100
